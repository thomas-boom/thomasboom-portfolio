---
// A simple responsive masonry-style photo grid component.
const { photos = [] } = Astro.props;
---

<div class="photo-grid">
	{photos.map((p) => (
		<figure class="photo">
			<a href={p.href || p.src} target="_blank" rel="noopener noreferrer">
				<img src={p.src} alt={p.alt || ''} loading="lazy" decoding="async" />
			</a>
			{p.caption ? <figcaption>{p.caption}</figcaption> : null}
		</figure>
	))}
</div>

<style>
.photo-grid {
	column-count: 3;
	column-gap: 1rem;
}
.photo {
	break-inside: avoid;
	-webkit-column-break-inside: avoid;
	margin-bottom: 1rem;
}
.photo img {
	width: 100%;
	height: auto;
	display: block;
	border-radius: 8px;
	box-shadow: var(--box-shadow);
}
.photo figcaption {
	font-size: 0.9rem;
	color: rgb(var(--gray-dark));
	margin-top: 0.5rem;
}
@media (max-width: 900px) {
	.photo-grid { column-count: 2; }
}
@media (max-width: 600px) {
	.photo-grid { column-count: 1; }
}
</style>
