---
const { photos = [], autoplay = true, interval = 5000, showControls = true, clickToNext = false } = Astro.props;
---

<div class="carousel" role="region" aria-roledescription="carousel" aria-label="Featured photos carousel" data-autoplay={autoplay} data-interval={String(interval)} data-show-controls={String(showControls)} data-click-next={String(clickToNext)}>
  <div class="carousel-viewport">
    <div class="carousel-track">
      {photos.map((p, i) => (
        <div class="carousel-slide" data-index={i} aria-hidden={i !== 0}>
          {clickToNext ? (
            <div class="carousel-click" role="button" tabindex="0" data-index={i} aria-label={`Next (image ${i + 1})`}>
              <img src={p.src} alt={p.alt || p.caption || ''} loading="lazy" decoding="async" />
            </div>
          ) : (
            <a href={p.href || p.src} target="_blank" rel="noopener noreferrer">
              <img src={p.src} alt={p.alt || p.caption || ''} loading="lazy" decoding="async" />
            </a>
          )}
        </div>
      ))}
    </div>
  </div>

  <button class="carousel-prev" aria-label="Previous slide" type="button">‹</button>
  <button class="carousel-next" aria-label="Next slide" type="button">›</button>

  <div class="carousel-dots" aria-hidden="false">
    {photos.map((p, i) => (
      <button class="carousel-dot" data-index={i} aria-label={`Go to slide ${i + 1}`} type="button" aria-current={i === 0 ? 'true' : 'false'}></button>
    ))}
  </div>
</div>

<style>
.carousel { position: relative; width: 100%; overflow: visible; max-width: 900px; margin: 0 auto; }
.carousel-viewport { overflow: hidden; border-radius: 8px; position: relative; }
.carousel-track { position: relative; height: auto; }
.carousel-slide { position: absolute; inset: 0; width: 100%; display:flex; align-items:center; justify-content:center; opacity: 0; transition: opacity 0.45s cubic-bezier(.2,.8,.2,1); pointer-events: none; }
.carousel-slide.is-active { opacity: 1; z-index: 1; pointer-events: auto; }
.carousel-slide img { width:100%; height:auto; display:block; border-radius: 8px; box-shadow: var(--box-shadow); }
.carousel-click { width: 100%; cursor: pointer; }
.carousel-click img { display: block; width: 100%; }
.carousel-prev, .carousel-next { position: absolute; top: 50%; transform: translateY(-50%); background: rgba(255,255,255,0.9); border: 1px solid rgba(0,0,0,0.06); width:44px; height:44px; display:flex; align-items:center; justify-content:center; font-size:1.6rem; color: rgb(var(--black)); cursor:pointer; border-radius:999px; }
.carousel-prev { left: 8px; }
.carousel-next { right: 8px; }
.carousel-dots { display:flex; gap:0.5rem; justify-content:center; margin-top:0.75rem; }
.carousel-dot { width:10px; height:10px; border-radius:50%; background: rgba(var(--gray-dark),0.12); border:none; cursor:pointer; }
.carousel-dot[aria-current="true"] { background: var(--accent); }
.carousel:focus { outline: none; }
/* hide controls when requested */
.carousel[data-show-controls='false'] .carousel-prev,
.carousel[data-show-controls='false'] .carousel-next,
.carousel[data-show-controls='false'] .carousel-dots { display: none; }
@media (max-width: 720px){ .carousel-prev, .carousel-next { width:36px; height:36px; font-size:1.25rem; } }
</style>

<script>
(function () {
  const script = document.currentScript;
  if (!script) return;

  // Find the nearest preceding element with the `.carousel` class.
  let root = script.previousElementSibling;
  while (root && !(root.classList && root.classList.contains('carousel'))) {
    root = root.previousElementSibling;
  }
  // Fallback: search within parent
  if (!root && script.parentElement) root = script.parentElement.querySelector('.carousel');
  if (!root) return;

  const track = root.querySelector('.carousel-track');
  const slides = Array.from(root.querySelectorAll('.carousel-slide'));
  const prevBtn = root.querySelector('.carousel-prev');
  const nextBtn = root.querySelector('.carousel-next');
  const dots = Array.from(root.querySelectorAll('.carousel-dot'));
  const autoplay = root.dataset.autoplay === 'true';
  const clickToNext = root.dataset.clickNext === 'true';
  const interval = Number(root.dataset.interval) || 5000;

  let index = 0;
  let timer = null;

  function setViewportHeight(){
    const vp = root.querySelector('.carousel-viewport');
    if (!vp) return;
    const active = slides[index];
    if (!active) return;
    const img = active.querySelector('img');
    if (img && !img.complete) {
      img.addEventListener('load', () => { vp.style.height = active.offsetHeight + 'px'; }, { once: true });
    } else {
      vp.style.height = active.offsetHeight + 'px';
    }
  }

  function goTo(i) {
    if (!slides.length) return;
    index = ((i % slides.length) + slides.length) % slides.length;
    slides.forEach((s, idx) => {
      const active = idx === index;
      s.classList.toggle('is-active', active);
      s.setAttribute('aria-hidden', !active);
    });
    dots.forEach((d, idx) => d.setAttribute('aria-current', idx === index ? 'true' : 'false'));
    setViewportHeight();
  }

  function start() { if (autoplay && !timer) timer = setInterval(() => goTo(index + 1), interval); }
  function stop() { if (timer) { clearInterval(timer); timer = null; } }
  function restart() { stop(); start(); }

  if (prevBtn) prevBtn.addEventListener('click', () => { goTo(index - 1); restart(); });
  if (nextBtn) nextBtn.addEventListener('click', () => { goTo(index + 1); restart(); });
  dots.forEach(d => d.addEventListener('click', () => { goTo(Number(d.dataset.index)); restart(); }));

  // image click -> next
  if (clickToNext) {
    slides.forEach((s) => {
      const btn = s.querySelector('.carousel-click');
      if (btn) {
        btn.addEventListener('click', () => { goTo(index + 1); restart(); });
        btn.addEventListener('keydown', (e) => { if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); goTo(index + 1); restart(); } });
      } else {
        const a = s.querySelector('a');
        if (a) a.addEventListener('click', (e) => { e.preventDefault(); goTo(index + 1); restart(); });
      }
    });

    // Delegated fallback: ensure clicks advance even if per-slide listeners fail
    root.addEventListener('click', (e) => {
      const btn = e.target.closest && e.target.closest('.carousel-click');
      if (!btn || !root.contains(btn)) return;
      e.preventDefault();
      goTo(index + 1);
      restart();
    });

    root.addEventListener('keydown', (e) => {
      if (e.key !== 'Enter' && e.key !== ' ') return;
      const focused = document.activeElement;
      if (!focused) return;
      if (!root.contains(focused)) return;
      if (!focused.closest || !focused.closest('.carousel-click')) return;
      e.preventDefault();
      goTo(index + 1);
      restart();
    });
  }

  // pause on hover/focus
  root.addEventListener('mouseenter', stop);
  root.addEventListener('mouseleave', start);

  // touch support
  let startX = 0, deltaX = 0;
  root.addEventListener('touchstart', (e) => { startX = e.touches[0].clientX; deltaX = 0; }, { passive: true });
  root.addEventListener('touchmove', (e) => { deltaX = e.touches[0].clientX - startX; }, { passive: true });
  root.addEventListener('touchend', () => { if (Math.abs(deltaX) > 50) { if (deltaX < 0) goTo(index + 1); else goTo(index - 1); restart(); } });

  // keyboard
  root.tabIndex = 0;
  root.addEventListener('keydown', (e) => { if (e.key === 'ArrowLeft') { goTo(index - 1); restart(); } if (e.key === 'ArrowRight') { goTo(index + 1); restart(); } });

  // ensure viewport height updates on resize
  window.addEventListener('resize', setViewportHeight);

  // initialize
  goTo(0);
  start();
})();
</script>
