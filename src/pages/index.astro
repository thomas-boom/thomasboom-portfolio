---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import PhotoGrid from '../components/PhotoGrid.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
import '../styles/photography.css';

const photos = [
  { src: 'https://images.unsplash.com/photo-1504198458649-3128b932f49b?auto=format&fit=crop&w=1200&q=80', alt: 'Mountain landscape', caption: 'Dawn light on the ridgeline' },
  { src: 'https://images.unsplash.com/photo-1496307042754-b4aa456c4a2d?auto=format&fit=crop&w=1200&q=80', alt: 'Forest path', caption: 'Quiet forest path' },
  { src: 'https://images.unsplash.com/photo-1470770903676-69b98201ea1c?auto=format&fit=crop&w=1200&q=80', alt: 'City skyline', caption: 'City skyline at dusk' },
  { src: 'https://images.unsplash.com/photo-1501785888041-af3ef285b470?auto=format&fit=crop&w=1200&q=80', alt: 'Desert', caption: 'Wind-carved dunes' },
  { src: 'https://images.unsplash.com/photo-1493244040629-496f6d136cc3?auto=format&fit=crop&w=1200&q=80', alt: 'Portrait', caption: 'Candid portrait study' },
  { src: 'https://images.unsplash.com/photo-1500530855697-b586d89ba3ee?auto=format&fit=crop&w=1200&q=80', alt: 'Ocean', caption: 'Waves and horizon' },
  { src: 'https://images.unsplash.com/photo-1469474968028-56623f02e42e?auto=format&fit=crop&w=1200&q=80', alt: 'Bridge', caption: 'Bridge in morning fog' },
  { src: 'https://images.unsplash.com/photo-1441974231531-c6227db76b6e?auto=format&fit=crop&w=1200&q=80', alt: 'Architecture', caption: 'Minimal architecture' }
];
---

<!doctype html>
<html lang="en">
  <head>
	<BaseHead title={`Photography — ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
  </head>
  <body>
	<Header />
	<main>
	  <h1>Photography</h1>
	  <p class="lead">A curated selection of photographs. Click any image to view full size.</p>
	  <PhotoGrid photos={photos} />
	</main>
	<Footer />
  </body>
</html>
