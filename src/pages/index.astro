---
import Carousel from '../components/Carousel.astro';
import '../styles/global.css';

const posts = [
  {
    title: "Untitled",
    image: "/blog-placeholder-1.jpg",
    year: "2025",
  },
  {
    title: "Rotterdam",
    image: "/blog-placeholder-2.jpg",
    year: "2025",
  },
  {
    title: "Family",
    image: "/blog-placeholder-3.jpg",
    year: "2024",
  },
  {
    title: "Landscape",
    image: "/blog-placeholder-4.jpg",
    year: "2024",
  },
];

const photos = posts.map(p => ({ src: p.image, alt: p.title, caption: p.year }));
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>Thomas Boom</title>
  </head>

  <body>
    <div class="layout">
      <main class="content centered">
        <Carousel photos={photos} showControls={false} clickToNext={true} autoplay={false} />
      </main>

      <aside class="sidebar">
        <div class="brand">
          <div class="name">Thomas Boom</div>
          <div class="bio">Artist & photographer based in Rotterdam.</div>
        </div>

        <nav>
          <a href="/">Work</a>
          <a href="/about">About</a>
          <a href="mailto:hello@thomasboom.nl">Contact</a>
          <a href="https://instagram.com">Instagram</a>
        </nav>
        <div class="brand-spacer" aria-hidden="true">
          <div class="name">Thomas Boom</div>
          <div class="bio">Artist & photographer based in Rotterdam.</div>
        </div>
      </aside>
    </div>
  </body>
</html>