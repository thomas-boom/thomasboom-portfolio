---
const posts = [
  {
    title: "Untitled",
    image: "/images/01.jpg",
    year: "2025",
  },
  {
    title: "Rotterdam",
    image: "/images/02.jpg",
    year: "2025",
  },
  {
    title: "Family",
    image: "/images/03.jpg",
    year: "2024",
  },
  {
    title: "Landscape",
    image: "/images/04.jpg",
    year: "2024",
  },
];
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>Thomas Boom</title>

    <style>
      :root {
        --bg: #ffffff;
        --text: #111111;
        --muted: #777777;
      }

      * {
        box-sizing: border-box;
      }

      html,
      body {
        margin: 0;
        padding: 0;
        background: var(--bg);
        color: var(--text);
        font-family: Arial, Helvetica, sans-serif;
        font-size: 13px;
        line-height: 1.4;
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      .layout {
        display: grid;
        grid-template-columns: 220px 1fr;
        min-height: 100vh;
      }

      .sidebar {
        position: fixed;
        width: 220px;
        height: 100vh;
        padding: 32px 24px;
        border-right: 1px solid #efefef;
      }

      .name {
        font-size: 13px;
        margin-bottom: 24px;
        text-transform: uppercase;
        letter-spacing: 0.04em;
      }

      .bio {
        color: var(--muted);
        margin-bottom: 32px;
        max-width: 150px;
      }

      nav {
        display: flex;
        flex-direction: column;
        gap: 10px;
      }

      nav a:hover {
        opacity: 0.5;
      }

      .content {
        margin-left: 220px;
        padding: 24px;
      }

      .grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 24px;
      }

      .post {
        display: flex;
        flex-direction: column;
      }

      .post img {
        width: 100%;
        display: block;
      }

      .meta {
        margin-top: 8px;
        display: flex;
        justify-content: space-between;
        color: var(--muted);
        font-size: 11px;
      }

      @media (max-width: 800px) {
        .layout {
          display: block;
        }

        .sidebar {
          position: relative;
          width: 100%;
          height: auto;
          border-right: none;
          border-bottom: 1px solid #efefef;
        }

        .content {
          margin-left: 0;
          padding: 16px;
        }

        .grid {
          grid-template-columns: 1fr;
          gap: 16px;
        }
      }
    </style>
  </head>

  <body>
    <div class="layout">
      <aside class="sidebar">
        <div class="name">Thomas Boom</div>

        <div class="bio">
          Artist & photographer based in Rotterdam.
        </div>

        <nav>
          <a href="/">Work</a>
          <a href="/about">About</a>
          <a href="mailto:hello@thomasboom.nl">Contact</a>
          <a href="https://instagram.com">Instagram</a>
        </nav>
      </aside>

      <main class="content">
        <div class="grid">
          {posts.map((post) => (
            <article class="post">
              <img src={post.image} alt={post.title} loading="lazy" />

              <div class="meta">
                <span>{post.title}</span>
                <span>{post.year}</span>
              </div>
            </article>
          ))}
        </div>
      </main>
    </div>
  </body>
</html>