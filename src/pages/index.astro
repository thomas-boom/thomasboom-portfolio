---
import Carousel from '../components/Carousel.astro';
import '../styles/global.css';

const posts = [
  {
    title: "Untitled",
    image: "https://images.unsplash.com/photo-1777911045174-37d19edb0c02?q=80&w=2070&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D",
    year: "2025",
  },
  {
    title: "Rotterdam",
    image: "https://plus.unsplash.com/premium_photo-1777559750449-514dd9526440?q=80&w=2340&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D",
    year: "2025",
  }
];

const photos = posts.map(p => ({ src: p.image, alt: p.title, caption: p.year }));
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>Thomas Boom</title>
  </head>

  <body>
    <div class="layout">
      <main class="content centered">
        <Carousel photos={photos} showControls={false} clickToNext={true} autoplay={false} />
      </main>

      <aside class="sidebar">
        <div class="brand">
          <div class="name">Thomas Boom</div>
          <div class="bio">Artist & photographer based in Rotterdam.</div>
        </div>

        <nav>
          <a href="/to-meander">to meander</a>
          <a href="/2903">2903</a>
          <a href="mailto:hello@thomasboom.nl">Contact</a>
          <a href="https://instagram.com">Instagram</a>
        </nav>
        <div class="brand-spacer" aria-hidden="true">
          <div class="name">Thomas Boom</div>
          <div class="bio">Artist & photographer based in Rotterdam.</div>
        </div>
      </aside>
    </div>
  </body>
</html>