---
import Carousel from '../components/Carousel.astro';
import '../styles/global.css';

const posts = [
  {
    title: "Untitled",
    image: "/images/01.jpg",
    year: "2025",
  },
  {
    title: "Rotterdam",
    image: "/images/02.jpg",
    year: "2025",
  },
  {
    title: "Family",
    image: "/images/03.jpg",
    year: "2024",
  },
  {
    title: "Landscape",
    image: "/images/04.jpg",
    year: "2024",
  },
];

const photos = posts.map(p => ({ src: p.image, alt: p.title, caption: p.year }));
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>Thomas Boom</title>
  </head>

  <body>
    <div class="layout">
      <main class="content">
        <Carousel photos={photos} />

        <div class="grid">
          {posts.map((post) => (
            <article class="post">
              <img src={post.image} alt={post.title} loading="lazy" />

              <div class="meta">
                <span>{post.title}</span>
                <span>{post.year}</span>
              </div>
            </article>
          ))}
        </div>
      </main>

      <aside class="sidebar">
        <div class="brand">
          <div class="name">Thomas Boom</div>
          <div class="bio">Artist & photographer based in Rotterdam.</div>
        </div>

        <nav>
          <a href="/">Work</a>
          <a href="/about">About</a>
          <a href="mailto:hello@thomasboom.nl">Contact</a>
          <a href="https://instagram.com">Instagram</a>
        </nav>
        <div class="brand-spacer" aria-hidden="true">
          <div class="name">Thomas Boom</div>
          <div class="bio">Artist & photographer based in Rotterdam.</div>
        </div>
      </aside>
    </div>
  </body>
</html>