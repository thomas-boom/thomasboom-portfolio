---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Carousel from '../components/Carousel.astro';

const photos = [
  { src: 'https://images.unsplash.com/photo-1501785888041-af3ef285b470?auto=format&fit=crop&w=1600&q=80', alt: 'Desert', caption: 'Desert' },
  { src: 'https://images.unsplash.com/photo-1493244040629-496f6d136cc3?auto=format&fit=crop&w=1600&q=80', alt: 'Portrait', caption: 'Portrait' },
  { src: 'https://images.unsplash.com/photo-1500530855697-b586d89ba3ee?auto=format&fit=crop&w=1600&q=80', alt: 'Ocean', caption: 'Ocean' }
];
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={`2903 — Thomas Boom`} description="2903 photo set" />
  </head>
  <body>
    <Header />
    <main class="content centered">
      <Carousel photos={photos} showControls={false} clickToNext={true} autoplay={false} />
    </main>
    <Footer />
  </body>
</html>
